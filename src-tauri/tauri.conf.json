{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DrawAssistant",
  "version": "0.1.0",
  "identifier": "com.drawassistant.mobile",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DrawAssistant",
        "width": 1280,
        "height": 900,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "template": "src-tauri/ios-project.yml",
      "minimumSystemVersion": "15.0",
      "bundleVersion": "1"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
